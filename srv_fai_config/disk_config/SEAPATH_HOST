# <type> <mountpoint> <size>   <fs type> <mount options> <misc options>

# entire disk with LVM, separate /home

disk_config disk1 disklabel:gpt fstabkey:uuid align-at:1M

primary /boot/efi  512M  vfat    rw
primary -          30G	 -       -
primary -          2G	 -       -

disk_config lvm

vg vg2  disk1.2
vg2-root    /          15G      ext4    noatime,rw lvcreateopts="--zero n"
vg2-varlog  /var/log    5G      ext4    noatime,rw lvcreateopts="--zero n"
vg2-swap    swap      500M      swap    sw lvcreateopts="--zero n"

#vg vg_ceph  disk1.3
#vg_ceph-lv_ceph -           1G   -       -
